generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ------------------------------------------------------------------

enum Plan {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
  AUDITOR
}

enum FrameworkType {
  GDPR
  ISO_27001
  SOC2
  NIS2
  DORA
  EU_AI_ACT
  CYBER_RESILIENCE_ACT
  PRODUCT_LIABILITY
  CUSTOM
}

enum FrameworkStatus {
  NOT_STARTED
  IN_PROGRESS
  AUDIT_READY
  CERTIFIED
  EXPIRED
}

enum ControlStatus {
  NOT_APPLICABLE
  NOT_STARTED
  IN_PROGRESS
  COMPLIANT
  NON_COMPLIANT
  NEEDS_REVIEW
}

enum ControlPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum EvidenceType {
  DOCUMENT
  SCREENSHOT
  LOG_EXPORT
  POLICY
  CERTIFICATE
  ATTESTATION
  AUTOMATED
}

enum EvidenceStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum RiskLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFORMATIONAL
}

enum RiskStatus {
  OPEN
  IN_TREATMENT
  ACCEPTED
  RESOLVED
  TRANSFERRED
}

enum PolicyStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum ScanStatus {
  QUEUED
  RUNNING
  AWAITING_CLARIFICATION
  COMPLETED
  FAILED
}

enum ControlResultStatus {
  PASS
  FAIL
  PARTIAL
  NO_EVIDENCE
}

enum IntegrationType {
  GITHUB
  GITLAB
  JIRA
  SLACK
  AWS
  GCP
  AZURE
  GOOGLE_WORKSPACE
  MICROSOFT_365
  OKTA
  CUSTOM_WEBHOOK
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  SYNCING
}

enum VendorRiskLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum AuditAction {
  CREATED
  UPDATED
  DELETED
  APPROVED
  REJECTED
  EXPORTED
  SHARED
  CONNECTED
  DISCONNECTED
  LOGIN
  LOGOUT
  PLAN_CHANGED
  MEMBER_INVITED
  MEMBER_REMOVED
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
}

// --- MODELS -----------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  avatarUrl String?
  plan      Plan     @default(FREE)

  marketingConsent Boolean   @default(false)
  consentUpdatedAt DateTime?

  onboardingComplete Boolean   @default(false)
  lastActiveAt       DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  ownedOrgs     Organization[]
  memberships   OrgMember[]
  notifications Notification[]
  auditLogs     AuditLog[]

  @@index([clerkId])
  @@index([email])
}

model Organization {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  logoUrl  String?
  website  String?
  industry String?
  size     String?
  country  String?

  usesAI         Boolean  @default(false)
  aiDescription  String?  @db.Text
  dataCategories String[]

  productDescription  String?  @db.Text
  aiPurposes          String[]
  userTypes           String[]
  usesThirdPartyAI    Boolean  @default(false)
  thirdPartyProviders String[]
  trainsOwnModels     Boolean  @default(false)
  hasPrivacyPolicy    Boolean  @default(false)

  riskTier                 String?
  applicableFrameworks     FrameworkType[]
  documentChecklist        Json?
  questionnaireAnswers     Json?
  questionnaireCompletedAt DateTime?

  plan    Plan   @default(FREE)
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  complianceScore Int       @default(0)
  scoreUpdatedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members               OrgMember[]
  frameworks            